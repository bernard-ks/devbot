# Recommended: run `npm run setup` and let the local setup tool write these
# Discord bootstrap values. Fill them manually only for headless setup.
DISCORD_TOKEN=replace-with-your-discord-bot-token
DISCORD_CLIENT_ID=replace-with-your-discord-application-client-id
DISCORD_GUILD_ID=replace-with-your-test-server-id

# Optional Discord-native visual workroom. It renders through Components V2 in
# the configured private Discord room and opens no HTTP listener or tunnel.
DEVBOT_STUDIO_ENABLED=false

# Immutable Discord user ID allowed to run /setup. Use an ID, not a username.
DEVBOT_OWNER_USER_ID=replace-with-your-discord-user-id

# Keep guild slash commands synchronized on startup. A local schema hash avoids
# repeated deployment during normal restarts.
DEVBOT_AUTO_DEPLOY_COMMANDS=true

# Optional: allow unmentioned natural-language follow-ups inside private task
# threads. Also enable Message Content Intent in the Discord developer portal.
DEVBOT_MESSAGE_CONTENT_INTENT=false

# Optional Codex CLI command or absolute path. On macOS, devbot also checks the
# current ChatGPT and legacy Codex app bundle locations when this is unavailable.
CODEX_BIN=codex

# Optional: override the model Codex uses. Empty means use your Codex default.
CODEX_MODEL=

# Optional request router. Luna classifies the request, Terra handles ordinary
# project work, and Sol handles broad/high-consequence reasoning.
CODEX_ROUTING_ENABLED=true
CODEX_ROUTER_MODEL=gpt-5.6-luna
CODEX_ROUTER_REASONING_EFFORT=low
CODEX_ROUTER_TIMEOUT_MS=30000
CODEX_FAST_MODEL=gpt-5.6-luna
CODEX_FAST_REASONING_EFFORT=low
CODEX_STANDARD_MODEL=gpt-5.6-terra
CODEX_STANDARD_REASONING_EFFORT=medium
CODEX_DEEP_MODEL=gpt-5.6-sol
CODEX_DEEP_REASONING_EFFORT=ultra
CODEX_FOCUSED_CONTEXT_CHARS=24000

# Optional bounded project-context scanner controls. Invalid, fractional,
# negative, or excessively large values fail startup instead of disabling a
# limit. Private .devbot/.codex state and environment files are never indexed.
DEVBOT_CONTEXT_MAX_INDEXED_FILE_BYTES=80000
DEVBOT_CONTEXT_MAX_INDEXED_FILES=2000
DEVBOT_CONTEXT_MAX_INDEXED_TOTAL_BYTES=8000000
DEVBOT_CONTEXT_MAX_SNIPPET_CHARS_PER_FILE=12000
DEVBOT_CONTEXT_MAX_PACKED_CHARS=120000
DEVBOT_CONTEXT_MAX_RANKED_FILES=36
DEVBOT_CONTEXT_CACHE_TTL_MS=5000

# Discord answer requests must remain read-only; startup rejects other values.
CODEX_SANDBOX=read-only

# /do performs intentional edits inside the selected project. Normal mentions
# stay read-only. Only read-only and workspace-write are accepted here;
# danger-full-access is rejected.
CODEX_ACTION_SANDBOX=workspace-write

CODEX_TIMEOUT_MS=180000

# Optional executor selection. Codex supports answers and isolated changes;
# Claude is opt-in and answer-only. Gemini/opencode are detection-only until
# their safety capabilities are verified against real CLIs.
# DEVBOT_AGENT_BACKEND=codex
# DEVBOT_CLAUDE_BIN=claude
# DEVBOT_CLAUDE_FAST_MODEL=
# DEVBOT_CLAUDE_STANDARD_MODEL=
# DEVBOT_CLAUDE_DEEP_MODEL=
# DEVBOT_GEMINI_BIN=gemini
# DEVBOT_OPENCODE_BIN=opencode

# Runtime ledgers default to ~/.devbot/state, outside every managed checkout.
# Existing checkout-local defaults migrate on first use. Override the protected
# root here, or use a specific per-store override below.
# DEVBOT_STATE_DIR=/absolute/path/to/devbot-state

# Optional: override where isolated per-task Git worktrees are created.
# Defaults to ~/.devbot/worktrees, outside configured source checkouts.
# DEVBOT_WORKTREE_ROOT=/absolute/path/to/devbot-worktrees

# Optional: override the local task-history JSON file.
# Defaults to ~/.devbot/state/tasks.json.
# DEVBOT_TASK_STORE=/absolute/path/to/devbot-state/tasks.json

# Optional: override the crash-recovery execution ledger.
# Defaults to ~/.devbot/state/executions.json.
# DEVBOT_EXECUTION_STORE=/absolute/path/to/devbot-state/executions.json

# Optional: override the managed task-preview ledger.
# Defaults to ~/.devbot/state/previews.json.
# DEVBOT_PREVIEW_STORE=/absolute/path/to/devbot-state/previews.json

# Optional: override the local peer-registry JSON file.
# Defaults to ~/.devbot/state/peers.json.
# DEVBOT_PEER_STORE=/absolute/path/to/devbot-state/peers.json

# Optional: override the local collaboration-lab JSON file.
# Defaults to ~/.devbot/state/collab.json.
# DEVBOT_COLLAB_STORE=/absolute/path/to/devbot-state/collab.json

# Optional: override owner-managed access, peer, room, and repo state.
# Defaults to ~/.devbot/state/setup.json.
# DEVBOT_SETUP_STORE=/absolute/path/to/devbot-state/setup.json

# Optional: override per-user selected-project preferences for the Discord workspace.
# Defaults to ~/.devbot/state/preferences.json.
# DEVBOT_PREFERENCES_STORE=/absolute/path/to/devbot-state/preferences.json

# Optional: override pending screenshot-analysis records.
# Defaults to ~/.devbot/state/screenshot-fixes.json.
# DEVBOT_SNAPFIX_STORE=/absolute/path/to/devbot-state/screenshot-fixes.json

# Optional: override the central directory for per-project memory (decisions, notes, task outcomes).
# Defaults to ~/.devbot/state/memory, outside every managed checkout.
# DEVBOT_MEMORY_STORE=/absolute/path/to/devbot-state/memory

# Optional: override the local PID file used to prevent duplicate bot runtimes.
# Defaults to ~/.devbot/state/runtime.pid.
# DEVBOT_RUNTIME_LOCK=/absolute/path/to/devbot-state/runtime.pid

# Optional: disable write-capable bot actions such as /do, action retries,
# configured command runs, and review validation.
DEVBOT_SAFE_MODE=false

# Optional bot identity used in peer announcements.
BOT_OWNER=local
BOT_DISPLAY_NAME=devbot

# Optional comma-separated allowlist of peer Discord bot user IDs.
PEER_BOT_IDS=

# Optional private text-channel or private-thread ID where peer messages should be posted.
# Required for peer participation in sealed councils; restrict it to approved humans and peer bots.
COORDINATION_CHANNEL_ID=

# Access is deny-by-default: besides the owner, only users granted view/control
# through `/setup user` or matched by the allowlists below can invoke the bot.
# Leaving all three allowlists empty does NOT open access to everyone.

# Optional: only these Discord users can invoke the bot. Comma-separated IDs.
ALLOWED_USER_IDS=

# Optional: only these Discord account usernames can invoke the bot. Comma-separated, case-insensitive.
# Guild nicknames and global display names are intentionally ignored; IDs remain the most stable option.
ALLOWED_USERNAMES=

# Optional: only members with one of these roles can invoke the bot. Comma-separated IDs.
ALLOWED_ROLE_IDS=

# Optional inline project map. If omitted, config/projects.json is used.
# Keep machine-specific paths in env and reference them from PROJECTS_JSON or config/projects.json.
# DEVBOT_PROJECT_ROOT=/path/to/local/webapp
# PROJECTS_JSON={"webapp":"${DEVBOT_PROJECT_ROOT}"}

# Optional static default when multiple bootstrap projects are configured.
# Discord-managed setup can select or replace this default at runtime.
DEFAULT_PROJECT=

# Optional screenshot URL overrides. Project metadata frontendUrl is preferred when present.
# PROJECT_SCREENSHOT_URL=http://127.0.0.1:3000
# PROJECT_SCREENSHOT_URLS_JSON={"webapp":"http://127.0.0.1:3000"}
