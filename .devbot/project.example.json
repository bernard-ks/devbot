{
  "canonicalName": "webapp",
  "repoUrl": "git@github.com:example/webapp.git",
  "defaultBranch": "main",
  "frontendUrl": "http://127.0.0.1:3000",
  "backendUrl": "http://127.0.0.1:8787",
  "ownerBot": "local-devbot",
  "aliases": ["web", "frontend"],
  "commands": {
    "test": ["npm test"],
    "build": ["npm run build"],
    "lint": ["npm run lint"],
    "verify": ["npm run build && npm test"],
    "presets": {
      "web-build": "npm run build",
      "quick-check": "npm run build"
    }
  },
  "policy": {
    "visibility": "team",
    "allowedUsers": [],
    "allowedRoles": [],
    "allowedPeers": [],
    "screenshotPolicy": "allow",
    "maxContextChars": 120000,
    "readOnlyCommands": ["test", "lint"],
    "approvalRequiredCommands": ["verify", "web-build"]
  }
}
